{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about an Ojas Care member.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth UID." },
        "name": { "type": "string", "description": "Full name of the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "provider": { "type": "string", "description": "The auth provider used (e.g., google, password)." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the platform." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the account was created." },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Timestamp of the last login." }
      },
      "required": ["uid", "email", "name"]
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles indexed by their Auth UID."
    }
  }
}